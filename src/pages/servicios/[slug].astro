---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config/site';
import { servicePages, getServicePage } from '../../content/servicePages';

export function getStaticPaths() {
  return servicePages.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const wa = siteConfig.social.whatsapp;
---

<Layout title={service.title} description={service.metaDescription}>
  <section class="pt-32 pb-16 bg-secondary">
    <div class="container mx-auto px-4 md:px-6 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">{service.title}</h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">{service.hero}</p>
    </div>
  </section>

  <section class="py-16 bg-neutral-bg dark:bg-secondary">
    <div class="container mx-auto px-4 md:px-6 max-w-4xl">
      <p class="text-lg text-neutral-text dark:text-gray-300 mb-12">{service.intro}</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        {service.bullets.map((b) => (
          <div class="bg-white dark:bg-secondary-light p-6 rounded-lg shadow-lg border border-primary/10">
            <h3 class="font-bold text-lg text-secondary dark:text-white mb-2">{b.title}</h3>
            <p class="text-neutral-text dark:text-gray-300">{b.text}</p>
          </div>
        ))}
      </div>

      <h2 class="text-2xl font-bold text-secondary dark:text-white mb-6">Cómo funciona</h2>
      <ol class="space-y-4 mb-16">
        {service.steps.map((step, i) => (
          <li class="flex items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-white font-bold flex items-center justify-center mr-4">{i + 1}</span>
            <span class="text-neutral-text dark:text-gray-300 pt-1">{step}</span>
          </li>
        ))}
      </ol>

      <div class="bg-secondary-light dark:bg-secondary-light rounded-lg p-8 text-center">
        <p class="text-lg text-gray-200 mb-6">{service.closing}</p>
        <a href={wa} target="_blank" rel="noopener" class="inline-block bg-primary text-white py-3 px-8 rounded-md font-bold hover:bg-primary-dark transition-all">
          Escribinos por WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
