---
import CTASection from '../components/home/CTASection.astro';
import FAQSection from '../components/home/FAQSection';
import HeroSection from '../components/home/HeroSection.astro';
import HowItWorksSection from '../components/home/HowItWorksSection.astro';
import ServicesSection from '../components/home/ServicesSection.astro';
import Layout from '../layouts/Layout.astro';
import { seo } from '../config/seo';
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
  <HeroSection />
  <ServicesSection />
  <HowItWorksSection />
  <div id="faq">
    <FAQSection client:visible />
  </div>
  <CTASection />
</Layout>
