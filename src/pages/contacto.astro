---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';

const wa = siteConfig.social.whatsapp;
const phoneHref = `tel:${siteConfig.phone.replace(/[^\d+]/g, '')}`;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${siteConfig.address}, Nicaragua`)}`;
// Exact pin from the HIT CARGO Google Business Profile ("Embed a map" src). CSP frame-src allows
// www.google.com so this iframe loads.
const mapEmbed = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3901.751261914731!2d-86.1942389249387!3d12.060627788177209!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8f73ffd16aa2686f%3A0x33b21079da1210!2sHIT%20CARGO!5e0!3m2!1sen!2sni!4v1783753731029!5m2!1sen!2sni';

// Inline SVGs so the static Astro page needs no icon runtime (lucide-preact is island-only).
// lucide (stroke) for field glyphs, simple-icons (fill) for brand marks. Trusted static markup.
const icon = {
  whatsapp: `<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>`,
  phone: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  mail: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  pin: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  clock: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  facebook: `<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  tiktok: `<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`,
};

const details = [
  { label: 'WhatsApp', value: 'Escribinos por WhatsApp', href: wa, external: true, icon: icon.whatsapp },
  { label: 'Teléfono', value: siteConfig.phone, href: phoneHref, icon: icon.phone },
  { label: 'Correo', value: siteConfig.email, href: `mailto:${siteConfig.email}`, icon: icon.mail },
  { label: 'Dirección', value: siteConfig.address, href: mapsUrl, external: true, icon: icon.pin },
  { label: 'Horario', value: 'Lunes a viernes, 8:00 a.m. – 5:00 p.m. No trabajamos domingos.', icon: icon.clock },
];

const socials = [
  { name: 'Facebook', url: siteConfig.social.facebook, icon: icon.facebook },
  { name: 'Instagram', url: siteConfig.social.instagram, icon: icon.instagram },
  { name: 'TikTok', url: siteConfig.social.tiktok, icon: icon.tiktok },
];
---

<Layout
  title="Contacto"
  description="Contactá a HIT CARGO Nicaragua por WhatsApp, teléfono o correo. Te asesoramos con tus importaciones desde USA, China y Panamá."
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-32 pb-20 bg-secondary">
    <div class="pointer-events-none absolute -top-24 -right-24 h-72 w-72 rounded-full bg-primary opacity-10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-navy opacity-30 blur-3xl"></div>
    <div class="container relative mx-auto px-4 md:px-6 text-center">
      <span class="inline-block rounded-full bg-primary/15 px-4 py-1 text-sm font-semibold uppercase tracking-wide text-primary">Estamos para ayudarte</span>
      <h1 class="mt-4 text-3xl md:text-5xl font-bold text-white">Contactanos</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
        Cotizá, rastreá o resolvé cualquier duda. Te respondemos rápido — la vía más ágil es WhatsApp.
      </p>
    </div>
  </section>

  <!-- Body -->
  <section class="py-16 bg-neutral-bg dark:bg-secondary">
    <div class="container mx-auto px-4 md:px-6 max-w-5xl">
      <div class="grid gap-6 lg:grid-cols-5 lg:gap-8">
        <!-- Contact details -->
        <div class="lg:col-span-3 rounded-2xl border border-primary/10 bg-white p-6 shadow-lg dark:bg-secondary-light md:p-8">
          <h2 class="mb-6 text-xl font-bold text-secondary dark:text-white">Datos de contacto</h2>
          <ul class="space-y-4">
            {details.map((d) => {
              const Row = (
                <div class="flex items-start gap-4">
                  <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-primary/10 text-primary" set:html={d.icon} />
                  <div class="min-w-0">
                    <span class="block text-xs font-semibold uppercase tracking-wide text-neutral-text dark:text-gray-400">{d.label}</span>
                    <span class="mt-0.5 block break-words text-lg font-medium text-secondary group-hover:text-primary dark:text-white">{d.value}</span>
                  </div>
                </div>
              );
              return (
                <li>
                  {d.href ? (
                    <a
                      href={d.href}
                      target={d.external ? '_blank' : undefined}
                      rel={d.external ? 'noopener noreferrer' : undefined}
                      class="group block rounded-xl p-2 transition-colors hover:bg-primary/5"
                    >
                      {Row}
                    </a>
                  ) : (
                    <div class="p-2">{Row}</div>
                  )}
                </li>
              );
            })}
          </ul>

          <div class="mt-8 border-t border-gray-100 pt-6 dark:border-white/10">
            <span class="text-xs font-semibold uppercase tracking-wide text-neutral-text dark:text-gray-400">Seguinos</span>
            <div class="mt-3 flex gap-3">
              {socials.map((s) => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.name}
                  title={s.name}
                  class="grid h-11 w-11 place-items-center rounded-full bg-secondary/5 text-secondary transition-colors hover:bg-primary hover:text-white dark:bg-white/5 dark:text-white"
                  set:html={s.icon}
                />
              ))}
            </div>
          </div>
        </div>

        <!-- Action cards -->
        <div class="flex flex-col gap-6 lg:col-span-2">
          <div class="rounded-2xl bg-primary p-6 text-white shadow-lg md:p-8">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-white/20" set:html={icon.whatsapp} />
            <h3 class="mt-4 text-xl font-bold">¿Listo para enviar?</h3>
            <p class="mt-1 text-sm text-white/90">Escribinos y te cotizamos al instante. Respuesta rápida, de persona real.</p>
            <a
              href={wa}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-white px-5 py-3 font-bold text-primary transition-transform hover:scale-[1.02]"
            >
              <span class="h-5 w-5" set:html={icon.whatsapp} /> Escribinos por WhatsApp
            </a>
          </div>

          <div class="rounded-2xl bg-navy p-6 text-white shadow-lg md:p-8">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-white/10 text-white" set:html={icon.pin} />
            <h3 class="mt-4 text-xl font-bold">Visitanos</h3>
            <p class="mt-1 text-sm text-white/80">{siteConfig.address}</p>
            <a
              href={mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex items-center gap-2 rounded-lg border border-white/30 px-5 py-3 font-semibold text-white transition-colors hover:bg-white/10"
            >
              Cómo llegar →
            </a>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="mt-8 overflow-hidden rounded-2xl border border-primary/10 shadow-lg">
        <iframe
          title="Ubicación de HIT CARGO en Google Maps"
          src={mapEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="block h-[360px] w-full border-0 md:h-[440px]"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
