---
import Header from '../components/layout/Header';
import Footer from '../components/layout/Footer.astro';
import JSONLD from '../components/seo/JSONLD.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
  image?: string;
  canonicalURL?: string;
}

const { 
  title, 
  description = "HIT CARGO: Importaciones de todo el mundo a Nicaragua. Gestión de envíos desde Miami, China y Panamá con logística profesional y entregas nacionales.",
  image = "/og-image.png",
  canonicalURL = Astro.url.href,
} = Astro.props;

const fullTitle = `${title} | HIT CARGO Nicaragua`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
    <JSONLD />

    <!-- SEO Meta Tags -->
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Dark mode initialization script (must load before body renders) -->
    <script is:inline src="/scripts/dark-mode-init.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-neutral-bg dark:bg-secondary transition-colors duration-300 min-h-screen flex flex-col">
    <Header client:load />
		<main class="flex-grow">
			<slot />
		</main>
    <Footer />
	</body>
</html>
