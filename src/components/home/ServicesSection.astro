---
import { serviceTitle, serviceDescription, services }  from "../../content/services";
---

<section class="py-20 bg-neutral-bg dark:bg-secondary">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary dark:text-white mb-4">{serviceTitle}</h2>
      <p class="text-xl text-neutral-text dark:text-gray-300 max-w-3xl mx-auto">
        {serviceDescription}
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="bg-white dark:bg-secondary-light p-6 rounded-lg shadow-lg transition-all duration-300 hover:shadow-xl hover:-translate-y-2 border border-primary/10 hover:border-primary/30 group">
          <div class="bg-neutral-bg dark:bg-secondary p-3 rounded-full inline-block mb-4 group-hover:bg-primary/10 transition-colors">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="text-xl font-bold text-secondary dark:text-white mb-3">{service.title}</h3>
          <p class="text-neutral-text dark:text-gray-300 mb-4">{service.description}</p>
          <a 
            href={service.linkUrl} 
            class="text-primary font-medium hover:text-primary-dark transition-colors inline-flex items-center"
          >
            Saber más <span class="ml-2 transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      ))}
    </div>
    
    <div class="text-center mt-12">
      <button class="bg-secondary text-white py-3 px-8 rounded-md font-bold hover:bg-secondary-light transition-all shadow-lg">
        Ver Todos los Servicios
      </button>
    </div>
  </div>
</section>
