---
import { title, description, ctaButtonText, contactButtonText } from '../../content/cta'
---

<section class="py-20 bg-secondary dark:bg-secondary-light">
  <div class="container mx-auto px-4 md:px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 -mt-10 -mr-10 w-64 h-64 bg-accent-yellow opacity-10 rounded-full"></div>
    <div class="absolute bottom-0 left-0 -mb-10 -ml-10 w-48 h-48 bg-primary opacity-10 rounded-full"></div>
    
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 animate-in fade-in slide-in-from-bottom duration-700">
        {title}
      </h2>
      <p class="text-xl text-gray-300 mb-10 animate-in fade-in slide-in-from-bottom duration-700 delay-200">
        {description}
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 animate-in fade-in slide-in-from-bottom duration-700 delay-400">
        <button class="bg-primary text-white py-4 px-8 text-lg rounded-md font-bold hover:bg-primary-dark transition-all transform hover:scale-105 shadow-lg">
          {ctaButtonText}
        </button>
        <button class="bg-transparent border-2 border-white text-white py-4 px-8 text-lg rounded-md font-bold hover:bg-white hover:text-secondary transition-all transform hover:scale-105">
          {contactButtonText}
        </button>
      </div>
    </div>
  </div>
</section>
