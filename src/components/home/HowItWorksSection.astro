---
const steps = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>',
    title: "Compra Online",
    description: "Compra en tus tiendas favoritas de Estados Unidos como Amazon, eBay o Shein."
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M7.5 4.27a2 2 0 0 0-2.73 2.73L2.34 9.43a2 2 0 0 0 .15 2.91l4.05 3.39c.39.33.91.52 1.45.52h6.02a2 2 0 0 0 1.45-.52l4.05-3.39a2 2 0 0 0 .15-2.91l-2.43-2.43a2 2 0 0 0-2.73-2.73L9.5 7.73l-2.01-2.01Z"/><path d="M12 13v8"/><path d="M21.16 9.17 19 11.33"/><path d="M2.84 9.17 5 11.33"/><path d="M17 17v4"/><path d="M7 17v4"/></svg>',
    title: "Envía a Nuestra Bodega",
    description: "Usa nuestra dirección de Estados Unidos para la entrega a nuestra bodega segura."
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.7 5.2c.3.4.8.5 1.3.3l.5-.3c.4-.2.6-.7.5-1.2z"/></svg>',
    title: "Enviamos a Nicaragua",
    description: "Elige entre envío aéreo o marítimo según tus necesidades."
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>',
    title: "Recibe tu Paquete",
    description: "Entregamos tu paquete directamente a tu puerta en Nicaragua."
  }
];
---

<section class="py-20 bg-white dark:bg-secondary-light overflow-hidden">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary dark:text-white mb-4">¿Cómo Funciona?</h2>
      <p class="text-xl text-neutral-text dark:text-gray-300 max-w-3xl mx-auto">
        Recibir tus paquetes desde Estados Unidos a Nicaragua es fácil con nuestro simple proceso de 4 pasos.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
      {steps.map((step, index) => (
        <div class="flex flex-col items-center md:items-start group">
          <div class="relative">
            <div class="bg-accent-yellow rounded-full p-4 z-10 relative shadow-lg transform group-hover:scale-110 transition-transform duration-300">
               <Fragment set:html={step.icon} />
            </div>
            {index < steps.length - 1 && (
              <div class="absolute top-1/2 left-1/2 w-full h-0.5 bg-primary opacity-30 hidden md:block" style="transform: translate(0, -50%); width: 100%;"></div>
            )}
          </div>
          <div class="mt-6 text-center md:text-left">
            <span class="inline-block bg-primary text-white text-sm font-bold rounded-full w-6 h-6 flex items-center justify-center mb-2">
              {index + 1}
            </span>
            <h3 class="text-xl font-bold text-secondary dark:text-white mb-2">{step.title}</h3>
            <p class="text-neutral-text dark:text-gray-300">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
